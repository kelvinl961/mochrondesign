---
import { contact } from '../data/site';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navItems = [
  { href: '/', label: 'HOME', chinese: '首页' },
  { href: '/gallery', label: 'GALLERY', chinese: '作品' },
  { href: '/about-us', label: 'About Us', chinese: '关于' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<button
  id="menu-toggle"
  type="button"
  class="fixed top-8 right-8 z-[70] flex h-12 w-12 items-center justify-center rounded-full bg-white/95 shadow-sm transition hover:bg-white"
  aria-expanded="false"
  aria-controls="menu-drawer"
  aria-label="Open menu"
>
  <span id="menu-icon" class="relative block h-2.5 w-5" aria-hidden="true">
    <span
      class="absolute left-0 top-0 block h-px w-5 bg-black transition-transform duration-300"
    ></span>
    <span
      class="absolute bottom-0 left-0 block h-px w-5 bg-black transition-transform duration-300"
    ></span>
  </span>
</button>

<div
  id="menu-overlay"
  class="fixed inset-0 z-[60] bg-black/10 opacity-0 pointer-events-none backdrop-blur-[1px] transition-opacity duration-300"
  aria-hidden="true"
></div>

<aside
  id="menu-drawer"
  class="fixed top-0 right-0 z-[80] flex h-full w-full max-w-[420px] translate-x-full flex-col bg-[#8e8e8e] text-white transition-transform duration-300 ease-out"
  aria-hidden="true"
>
  <div class="flex justify-end px-8 pt-8">
    <button
      id="menu-close"
      type="button"
      class="text-3xl font-light leading-none text-white transition hover:opacity-70"
      aria-label="Close menu"
    >
      ×
    </button>
  </div>

  <nav class="flex flex-col items-center gap-7 px-8 pt-10 text-center">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-[1.65rem] font-light tracking-wide transition hover:opacity-70',
            isActive(item.href) && 'opacity-100',
          ]}
        >
          {item.label} · {item.chinese}
        </a>
      ))
    }
  </nav>

  <div class="mx-10 my-10 border-t border-white/35"></div>

  <div class="flex flex-1 flex-col items-center px-8 text-center text-sm font-light leading-7">
    <p class="mb-6">
      Contact us<br />
      {contact.hours}
    </p>

    <div class="mb-5 flex items-start gap-3 text-left">
      <svg class="mt-1 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M6.6 10.8a15 15 0 006.6 6.6l2.2-2.2a1 1 0 011-.24 11 11 0 003.45.55 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 014 5a1 1 0 011-1h3.5a1 1 0 011 1 11 11 0 00.55 3.45 1 1 0 01-.25 1z"
          stroke="currentColor"
          stroke-width="1.2"></path>
      </svg>
      <div>
        {contact.phones.map((phone) => <p>{phone}</p>)}
      </div>
    </div>

    <div class="mb-5 flex items-start gap-3 text-left">
      <svg class="mt-1 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M4 6h16v12H4z"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linejoin="round"></path>
        <path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.2"></path>
      </svg>
      <a href={`mailto:${contact.email}`} class="transition hover:opacity-70">
        {contact.email}
      </a>
    </div>

    {
      contact.branches.map((branch) => (
        <div class="mb-5 flex items-start gap-3 text-left">
          <svg class="mt-1 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M12 21s6-5.2 6-10a6 6 0 10-12 0c0 4.8 6 10 6 10z"
              stroke="currentColor"
              stroke-width="1.2"></path>
            <circle cx="12" cy="11" r="2" stroke="currentColor" stroke-width="1.2"></circle>
          </svg>
          <p class="max-w-[18rem]">{branch.address}</p>
        </div>
      ))
    }
  </div>

  <div class="mx-10 mb-8 border-t border-white/35"></div>

  <div class="flex items-center justify-center gap-8 px-8 pb-10">
    <a
      href="https://www.xiaohongshu.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-medium tracking-widest transition hover:opacity-70"
      aria-label="Xiaohongshu"
    >
      小红书
    </a>
    <a
      href="https://www.facebook.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-lg transition hover:opacity-70"
      aria-label="Facebook"
    >
      f
    </a>
    <a
      href="https://www.instagram.com"
      target="_blank"
      rel="noopener noreferrer"
      class="transition hover:opacity-70"
      aria-label="Instagram"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="4" y="4" width="16" height="16" rx="4" stroke="currentColor" stroke-width="1.2"
        ></rect>
        <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.2"></circle>
        <circle cx="17" cy="7" r="1" fill="currentColor"></circle>
      </svg>
    </a>
  </div>
</aside>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const drawer = document.getElementById('menu-drawer');
  const overlay = document.getElementById('menu-overlay');
  const menuIcon = document.getElementById('menu-icon');
  const iconBars = menuIcon?.querySelectorAll('span');

  function setMenuOpen(isOpen: boolean) {
    const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;

    toggle?.setAttribute('aria-expanded', String(isOpen));
    drawer?.setAttribute('aria-hidden', String(!isOpen));
    overlay?.setAttribute('aria-hidden', String(!isOpen));

    drawer?.classList.toggle('translate-x-full', !isOpen);
    drawer?.classList.toggle('translate-x-0', isOpen);

    overlay?.classList.toggle('opacity-0', !isOpen);
    overlay?.classList.toggle('pointer-events-none', !isOpen);
    overlay?.classList.toggle('opacity-100', isOpen);
    overlay?.classList.toggle('pointer-events-auto', isOpen);

    iconBars?.[0]?.classList.toggle('translate-y-[4px]', isOpen);
    iconBars?.[0]?.classList.toggle('rotate-45', isOpen);
    iconBars?.[1]?.classList.toggle('-translate-y-[4px]', isOpen);
    iconBars?.[1]?.classList.toggle('-rotate-45', isOpen);

    document.documentElement.classList.toggle('overflow-hidden', isOpen);
    document.body.classList.toggle('overflow-hidden', isOpen);
    document.body.style.paddingRight = isOpen && scrollbarWidth > 0 ? `${scrollbarWidth}px` : '';
    if (toggle instanceof HTMLElement) {
      toggle.style.marginRight = isOpen && scrollbarWidth > 0 ? `${scrollbarWidth}px` : '';
    }
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setMenuOpen(!isOpen);
  });

  close?.addEventListener('click', () => setMenuOpen(false));
  overlay?.addEventListener('click', () => setMenuOpen(false));

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMenuOpen(false);
  });

  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });
</script>
