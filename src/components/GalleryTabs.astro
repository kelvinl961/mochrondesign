---
import type { CollectionEntry } from 'astro:content';
import GalleryGrid from './GalleryGrid.astro';

interface Props {
  completed: CollectionEntry<'projects'>[];
  visualization: CollectionEntry<'projects'>[];
}

const { completed, visualization } = Astro.props;
---

<div class="mb-12 flex flex-wrap items-center justify-center gap-4 md:gap-6">
  <img
    src="/images/brand/watermark.png"
    alt="Mochron Design"
    class="h-9 w-auto max-w-[180px] object-contain object-left md:h-11 md:max-w-[220px]"
    width="220"
    height="53"
    loading="eager"
  />
  <span class="hidden h-10 w-px shrink-0 bg-black sm:block md:h-12" aria-hidden="true"></span>
  <div class="flex flex-wrap justify-center gap-3">
    <button
      type="button"
      class="gallery-tab is-active"
      data-tab="completed"
      role="tab"
      aria-selected="true"
      aria-controls="gallery-panel-completed"
    >
      Completed Project
    </button>
    <button
      type="button"
      class="gallery-tab"
      data-tab="visualization"
      role="tab"
      aria-selected="false"
      aria-controls="gallery-panel-visualization"
    >
      Visualization
    </button>
  </div>
</div>

<GalleryGrid projects={completed} tabId="completed" />
<GalleryGrid projects={visualization} tabId="visualization" />

<style>
  .gallery-tab {
    @apply bg-pins-grey px-5 py-2 text-[10px] tracking-[0.25em] text-white uppercase transition;
  }

  .gallery-tab:not(.is-active):hover {
    @apply bg-black text-white;
  }

  .gallery-tab.is-active {
    @apply bg-[#d9d9d9] text-black;
  }

  .gallery-tab.is-active:hover {
    @apply bg-[#d9d9d9] text-black;
  }
</style>

<script>
  const tabs = [...document.querySelectorAll('.gallery-tab')];
  const panels = [...document.querySelectorAll('.gallery-panel')];

  function activateTab(tabName: string) {
    tabs.forEach((tab) => {
      const isActive = tab.getAttribute('data-tab') === tabName;
      tab.setAttribute('aria-selected', String(isActive));
      tab.classList.toggle('is-active', isActive);
    });

    panels.forEach((panel) => {
      const isActive = panel.getAttribute('data-tab-panel') === tabName;
      panel.classList.toggle('hidden', !isActive);
    });

    history.replaceState(null, '', `#${tabName}`);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const tabName = tab.getAttribute('data-tab');
      if (tabName) activateTab(tabName);
    });
  });

  const hash = window.location.hash.replace('#', '');
  if (hash === 'visualization' || hash === 'completed') {
    activateTab(hash);
  }
</script>
