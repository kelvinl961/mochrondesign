---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import type { ProjectTab } from '../utils/projects';

export const prerender = true;

const heroBanner = '/images/home-hero-banner.png';

const projects = await getCollection('projects');

function getCategoryImages(tab: ProjectTab) {
  const images = new Set<string>();

  for (const project of projects) {
    if (project.data.projectTab !== tab) continue;

    if (project.data.image) images.add(project.data.image);

    for (const item of project.data.gallery ?? []) {
      const url = typeof item === 'string' ? item : item.image;
      if (url) images.add(url);
    }
  }

  return [...images];
}

const completedImages = getCategoryImages('completed');
const visualizationImages = getCategoryImages('visualization');

const projectCategories = [
  {
    title: 'Completed Projects',
    href: '/gallery#completed',
    category: 'completed',
    images: completedImages,
  },
  {
    title: 'Visualization',
    href: '/gallery#visualization',
    category: 'visualization',
    images: visualizationImages,
  },
];
---

<SiteLayout title="HOME | Mochron Design">
  <header class="w-full bg-pins-light md:px-12 md:pt-12">
    <div class="relative w-full md:mx-auto md:max-w-5xl">
      <img
        src={heroBanner}
        alt="Mochron Design"
        class="block h-auto w-full"
        loading="eager"
      />

      <h1
        class="pointer-events-none absolute bottom-3 left-1/2 max-w-[85%] -translate-x-1/2 px-4 text-center text-xs font-light leading-relaxed tracking-[0.12em] text-black/70 sm:text-sm md:bottom-16 md:max-w-4xl md:px-6 md:text-4xl md:leading-normal md:text-black/75"
      >
        Designing &amp; building timeless space
      </h1>
    </div>
  </header>

  <section id="projects" class="marble-bg px-6 py-16 md:px-12 md:py-32">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 flex items-start gap-4 md:mb-16">
        <span class="mt-2 h-10 w-px bg-black md:h-12"></span>
        <div>
          <p class="mb-2 text-xs tracking-[0.35em] text-pins-muted uppercase">Explore</p>
          <h2 class="font-display text-4xl font-light md:text-7xl">Projects</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-5">
        {
          projectCategories.map((category) => (
            <a
              href={category.href}
              class="group block overflow-hidden bg-white"
              data-project-category={category.category}
            >
              <div class="aspect-[4/3] overflow-hidden">
                {
                  category.images.length > 0 ? (
                    <img
                      data-random-cover
                      src={category.images[0]}
                      alt={category.title}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                      loading="lazy"
                    />
                  ) : (
                    <div class="h-full w-full bg-pins-grey/20"></div>
                  )
                }
              </div>
              <p class="px-5 py-4 text-sm tracking-[0.28em] uppercase transition group-hover:opacity-60">
                {category.title}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <script define:vars={{ completedImages, visualizationImages }}>
    const imagesByCategory = {
      completed: completedImages,
      visualization: visualizationImages,
    };

    document.querySelectorAll('[data-project-category]').forEach((card) => {
      const category = card.getAttribute('data-project-category');
      const images = imagesByCategory[category] ?? [];
      const img = card.querySelector('[data-random-cover]');

      if (!category || !img || images.length === 0) return;

      img.src = images[Math.floor(Math.random() * images.length)];
    });
  </script>

  <section id="about" class="marble-bg px-6 py-16 md:px-12 md:py-32">
    <div class="mx-auto max-w-5xl">
      <p class="mb-4 text-xs tracking-[0.35em] text-pins-muted uppercase">About</p>
      <h2 class="max-w-4xl text-2xl font-light leading-relaxed md:text-4xl">
        Uniquely Tailored for You and Your Lifestyle
      </h2>
      <a
        href="/about-us"
        class="mt-8 inline-block text-xs tracking-[0.25em] uppercase underline-offset-4 hover:underline"
      >
        Read more →
      </a>
    </div>
  </section>

  <section id="service" class="bg-pins-light px-6 py-16 md:px-12 md:py-32">
    <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-[1fr_2fr]">
      <div>
        <p class="mb-2 text-xs tracking-[0.35em] text-pins-muted uppercase">Our</p>
        <h2 class="text-3xl tracking-pins uppercase md:text-4xl">Service</h2>
      </div>
      <div>
        <div class="max-w-3xl space-y-6 text-sm font-light leading-8 text-black/80 md:text-base">
          <p>
            At Mochron Design, we believe every space should be a true reflection
            of the people who live, work, and experience it. That's why every
            project we undertake is thoughtfully designed around your lifestyle,
            needs, and aspirations—not a one-size-fits-all approach.
          </p>
          <p>
            We are a full-service interior design and build studio specializing in
            both residential and commercial projects. From the initial consultation
            and concept development to space planning, material selection,
            construction, and final styling, we provide a seamless one-stop solution
            that brings your vision to life with confidence and peace of mind.
          </p>
          <p>
            Our collaborative design process combines creativity, functionality, and
            meticulous attention to detail to create spaces that are timeless,
            practical, and uniquely yours. Whether you're building your dream home,
            renovating an existing space, or transforming a commercial environment,
            we are committed to delivering exceptional craftsmanship and a smooth,
            transparent project experience from start to finish.
          </p>
          <p>
            At Mochron Design, we don't just design interiors, we create spaces that
            are uniquely tailored for you and your lifestyle.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Hero slider script — restore with slider markup above
  <script>
    const slides = [...document.querySelectorAll('.hero-slide')];
    ...
  </script>
  */}
</SiteLayout>
