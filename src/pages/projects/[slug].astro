---
import SiteLayout from '../../layouts/SiteLayout.astro';
import ImageViewer from '../../components/ImageViewer.astro';
import { getCollection } from 'astro:content';
import { formatProjectCaption, getGalleryImages } from '../../utils/projects';

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const caption = formatProjectCaption(project);
const images = getGalleryImages(project);
const backTab = project.data.projectTab === 'visualization' ? 'visualization' : 'completed';
---

<SiteLayout title={`${project.data.title} | Mochron Design`}>
  <main class="marble-bg min-h-screen">
    <section class="px-6 py-16 md:px-12 md:py-24">
      <div class="mx-auto max-w-6xl">
        <a
          href={`/gallery#${backTab}`}
          class="mb-10 inline-block text-xs tracking-[0.3em] uppercase transition hover:opacity-60"
        >
          ← back
        </a>

        <p class="mb-4 text-xs tracking-[0.35em] text-pins-muted uppercase">Gallery</p>

        <h1 class="mb-2 text-2xl tracking-[0.18em] uppercase md:text-3xl">
          {project.data.title}
        </h1>
        <p class="mb-10 text-sm font-light lowercase text-black/70">{caption.subtitle}</p>

        {
          (project.data.designConcept || project.data.designer || project.data.description) && (
            <div class="mb-12 space-y-4 text-sm font-light leading-8 md:text-base">
              {project.data.designConcept && (
                <p>
                  <span class="tracking-[0.15em] uppercase">Design Concept</span>
                  <span class="text-pins-muted"> / </span>
                  {project.data.designConcept}
                </p>
              )}
              {project.data.designer && (
                <p>
                  <span class="tracking-[0.15em] uppercase">Designer</span>
                  <span class="text-pins-muted"> / </span>
                  {project.data.designer}
                </p>
              )}
              {project.data.description && (
                <p class="text-black/75">{project.data.description}</p>
              )}
            </div>
          )
        }
      </div>
    </section>

    <section class="pb-24">
      <div class="mx-auto max-w-6xl px-6 md:px-12">
        <ImageViewer images={images} altPrefix={project.data.title} />
      </div>
    </section>
  </main>
</SiteLayout>
