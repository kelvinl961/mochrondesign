---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import { formatProjectCaption, getGalleryImages } from '../../utils/projects';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const caption = formatProjectCaption(project);
const images = getGalleryImages(project);
const backTab = project.data.projectTab === 'visualization' ? 'visualization' : 'completed';
---

<SiteLayout title={`${project.data.title} | Mochron Design`}>
  <main class="marble-bg min-h-screen">
    <section class="px-6 py-16 md:px-12 md:py-24">
      <div class="mx-auto max-w-6xl">
        <a
          href={`/gallery#${backTab}`}
          class="mb-10 inline-block text-xs tracking-[0.3em] uppercase transition hover:opacity-60"
        >
          ← back
        </a>

        <p class="mb-4 text-xs tracking-[0.35em] text-pins-muted uppercase">Gallery</p>

        <h1 class="mb-2 text-2xl tracking-[0.18em] uppercase md:text-3xl">
          {project.data.title}
        </h1>
        <p class="mb-10 text-sm font-light lowercase text-black/70">{caption.subtitle}</p>

        {
          (project.data.designConcept || project.data.designer) && (
            <div class="mb-12 space-y-2 text-sm font-light leading-8 md:text-base">
              {project.data.designConcept && (
                <p>
                  <span class="tracking-[0.15em] uppercase">Design Concept</span>
                  <span class="text-pins-muted"> / </span>
                  {project.data.designConcept}
                </p>
              )}
              {project.data.designer && (
                <p>
                  <span class="tracking-[0.15em] uppercase">Designer</span>
                  <span class="text-pins-muted"> / </span>
                  {project.data.designer}
                </p>
              )}
            </div>
          )
        }
      </div>
    </section>

    <section class="pb-24">
      <div id="project-slider" class="relative">
        {
          images.map((src, index) => (
            <div
              class:list={[
                'project-slide transition-opacity duration-700',
                index === 0 ? 'opacity-100' : 'absolute inset-0 opacity-0',
              ]}
              data-index={index}
            >
              <img
                src={src}
                alt={`${project.data.title} — image ${index + 1}`}
                class="mx-auto max-h-[80vh] w-full max-w-6xl object-contain px-6 md:px-12"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            </div>
          ))
        }
      </div>

      {
        images.length > 1 && (
          <>
            <div class="mt-8 flex items-center justify-center gap-6">
              <button
                id="project-prev"
                type="button"
                class="text-2xl font-light transition hover:opacity-60"
                aria-label="Previous image"
              >
                ←
              </button>
              <div id="project-dots" class="flex gap-2">
                {
                  images.map((_, index) => (
                    <button
                      type="button"
                      class:list={[
                        'project-dot h-2 w-2 transition',
                        index === 0 ? 'bg-black' : 'bg-black/25',
                      ]}
                      data-index={index}
                      aria-label={`Go to image ${index + 1}`}
                    />
                  ))
                }
              </div>
              <button
                id="project-next"
                type="button"
                class="text-2xl font-light transition hover:opacity-60"
                aria-label="Next image"
              >
                →
              </button>
            </div>
          </>
        )
      }

      {
        project.data.description && (
          <div class="mx-auto mt-16 max-w-3xl px-6 text-sm font-light leading-8 text-black/75 md:px-12 md:text-base">
            <p>{project.data.description}</p>
          </div>
        )
      }
    </section>
  </main>

  {
    images.length > 1 && (
      <script>
        const slides = [...document.querySelectorAll('.project-slide')];
        const dots = [...document.querySelectorAll('.project-dot')];
        const prev = document.getElementById('project-prev');
        const next = document.getElementById('project-next');
        let current = 0;

        function show(index: number) {
          if (!slides.length) return;
          current = (index + slides.length) % slides.length;

          slides.forEach((slide, i) => {
            const active = i === current;
            slide.classList.toggle('opacity-100', active);
            slide.classList.toggle('opacity-0', !active);
            slide.classList.toggle('absolute', !active);
            slide.classList.toggle('inset-0', !active);
            if (active) {
              slide.classList.remove('absolute', 'inset-0');
            }
          });

          dots.forEach((dot, i) => {
            dot.classList.toggle('bg-black', i === current);
            dot.classList.toggle('bg-black/25', i !== current);
          });
        }

        prev?.addEventListener('click', () => show(current - 1));
        next?.addEventListener('click', () => show(current + 1));
        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const index = Number(dot.getAttribute('data-index'));
            show(index);
          });
        });
      </script>
    )
  }
</SiteLayout>
