---
import SiteLayout from '../../layouts/SiteLayout.astro';
import GalleryTabs from '../../components/GalleryTabs.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const projects = await getCollection('projects');
const sortByTitle = (a: (typeof projects)[number], b: (typeof projects)[number]) =>
  a.data.title.localeCompare(b.data.title);

const completed = projects
  .filter((p) => p.data.projectTab === 'completed')
  .sort(sortByTitle);
const visualization = projects
  .filter((p) => p.data.projectTab === 'visualization')
  .sort(sortByTitle);
---

<SiteLayout
  title="GALLERY | Mochron Design"
  description="Browse Mochron Design portfolio — completed interior projects and 3D visualizations for residential and commercial spaces in Malaysia."
>
  <main class="marble-bg min-h-screen px-6 py-24 md:px-12 md:py-32">
    <div class="mx-auto max-w-screen-2xl">
      <GalleryTabs completed={completed} visualization={visualization} />
    </div>
  </main>
</SiteLayout>
